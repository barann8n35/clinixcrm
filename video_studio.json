    {
      "parameters": {
        "jsCode": "// Merge subtitle + dub URLs and prepare PATCH body\nconst srtSign = $('Sign SRT URL').item?.json;\nconst dubSign = $('Sign dub URL').item?.json;\nconst tr = $('Mark processing').item.json;\nconst SUPABASE_URL = $env.SUPABASE_URL;\n\nconst subtitle_url = srtSign?.signedURL ? `${SUPABASE_URL}/storage/v1${srtSign.signedURL}` : null;\nconst output_url = dubSign?.signedURL ? `${SUPABASE_URL}/storage/v1${dubSign.signedURL}` : null;\n\nreturn [{\n  json: {\n    id: tr.id,\n    update: {\n      status: 'completed',\n      completed_at: new Date().toISOString(),\n      transcript_text: $('Whisper transcription').item.json.text,\n      translated_text: $('Build SRT').item.json.translatedText,\n      subtitle_url,\n      output_url,\n    }\n  }\n}];"
      },
