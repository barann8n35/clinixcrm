    {
      "parameters": {
        "method": "POST",
        "url": "https://ai.gateway.lovable.dev/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.LOVABLE_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"google/gemini-2.5-flash\",\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"You are a professional medical translator. Translate while preserving medical terminology, tone and segment structure. Output VALID JSON only with shape {\\\"segments\\\":[{\\\"start\\\":number,\\\"end\\\":number,\\\"text\\\":string}]}.\"},\n    {\"role\": \"user\", \"content\": \"Translate the following transcript segments to {{ $('Mark processing').item.json.target_language_label }} ({{ $('Mark processing').item.json.target_language }}). Keep timestamps. Segments JSON:\\n\\n{{ JSON.stringify($json.segments) }}\"}\n  ],\n  \"response_format\": {\"type\": \"json_object\"}\n}",
        "options": {}
      },
      "id": "8b8e6a95-d4d3-4d2d-9b97-b80e21ea19e6",
      "name": "Translate (Lovable AI)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -368,
        -32
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build SRT from translated segments\nconst raw = $json.choices[0].message.content;\nconst parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\nconst segs = parsed.segments || [];\n\nconst pad = (n, l = 2) => String(n).padStart(l, '0');\nconst toTs = (s) => {\n  const h = Math.floor(s / 3600);\n  const m = Math.floor((s % 3600) / 60);\n  const sec = Math.floor(s % 60);\n  const ms = Math.round((s - Math.floor(s)) * 1000);\n  return `${pad(h)}:${pad(m)}:${pad(sec)},${pad(ms, 3)}`;\n};\n\nconst srt = segs.map((seg, i) => `${i + 1}\\n${toTs(seg.start)} --> ${toTs(seg.end)}\\n${seg.text}\\n`).join('\\n');\nconst translatedText = segs.map(s => s.text).join(' ');\n\nreturn [{\n  json: {\n    srt,\n    translatedText,\n    segments: segs,\n  },\n  binary: {\n    srt: {\n      data: Buffer.from(srt, 'utf-8').toString('base64'),\n      mimeType: 'application/x-subrip',\n      fileName: `subtitle_${$('Mark processing').item.json.target_language}.srt`,\n    }\n  }\n}];"
      },
      "id": "68f6307c-a0bb-419e-b961-18498e824a87",
